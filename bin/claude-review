#!/usr/bin/env node

import { reviewPR } from '../src/index.js';
import { parseArgs } from 'util';

const { values, positionals } = parseArgs({
  args: process.argv.slice(2),
  options: {
    pr: { type: 'string', short: 'p' },
    token: { type: 'string', short: 't' },
    model: { type: 'string', short: 'm', default: 'claude-3-5-sonnet' },
    post: { type: 'boolean', default: false },
    help: { type: 'boolean', short: 'h', default: false }
  },
  allowPositionals: true
});

const prUrl = values.pr || positionals[0];

if (values.help || !prUrl) {
  console.log(`
Claude Review - PR Review Agent

Usage:
  claude-review --pr <pr-url> [options]
  claude-review <pr-url> [options]

Options:
  --pr, -p <url>       PR URL (required)
  --token, -t <token> GitHub token (defaults to GITHUB_TOKEN env var)
  --model, -m <model>  Claude model (default: claaude-3-5-sonnet)
  --post               Post the review as a GitHub comment
  --help, -h           Show this help message

Examples:
  claude-review --pr https://github.com/owner/repo/pull/123
  claude-review https://github.com/owner/repo/pull/123 --post
  GITHUB_TOKEN=xxx claude-review --pr https://github.com/owner/repo/pull/456

Environment Variables:
  GITHUB_TOKEN    GitHub personal access token
  ANTHROPIC_KEY   Anthropic API key for Claude
`);
  process.exit(0);
}

const token = values.token || process.env.GITHUB_TOKEN;
const model = values.model;
const shouldPost = values.post;

try {
  const review = await reviewPR({
    prUrl,
    githubToken: token,
    model,
    postComment: shouldPost
  });
  console.log(review);
} catch (error) {
  console.error('Error:', error.message);
  process.exit(1);
}
