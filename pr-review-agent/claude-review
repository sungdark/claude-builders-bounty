#!/usr/bin/env node
/**
 * claude-review — PR Review Agent
 * Analyzes a GitHub PR diff and posts a structured review comment.
 * 
 * Usage:
 *   claude-review --pr https://github.com/owner/repo/pull/123
 *   claude-review --pr owner/repo/123
 *   claude-review --pr 123 --repo owner/repo --token GITHUB_TOKEN
 */

import { parseArgs } from "node:util";
import { readFileSync } from "node:fs";

const GITHUB_API = "https://api.github.com";

async function ghApi(endpoint, token) {
  const res = await fetch(`${GITHUB_API}${endpoint}`, {
    headers: {
      Authorization: `Bearer ${token}`,
      Accept: "application/vnd.github.v3+json",
      "X-GitHub-Api-Version": "2022-11-28",
    },
  });
  if (!res.ok) {
    const err = await res.text();
    throw new Error(`GitHub API error ${res.status}: ${err}`);
  }
  return res.json();
}

function parsePrUrl(prSpec) {
  // Formats:
  // https://github.com/owner/repo/pull/123
  // owner/repo/123
  // 123 (requires --repo)
  const urlMatch = prSpec.match(
    /github\.com\/([^/]+)\/([^/]+)\/pull\/(\d+)/
  );
  if (urlMatch) return { owner: urlMatch[1], repo: urlMatch[2], num: parseInt(urlMatch[3]) };
  
  const bareMatch = prSpec.match(/^([^/]+)\/([^/]+)\/(\d+)$/);
  if (bareMatch) return { owner: bareMatch[1], repo: bareMatch[2], num: parseInt(bareMatch[3]) };
  
  const numOnly = prSpec.match(/^\d+$/);
  if (numOnly) return { num: parseInt(prSpec) };
  
  throw new Error(`Invalid PR spec: ${prSpec}. Use --pr owner/repo/123 or full URL.`);
}

function buildReviewComment({ owner, repo, num, summary, risks, suggestions, confidence }) {
  return `## 🤖 Claude Code PR Review — #${num}

### Summary
${summary}

### Risk Assessment
${risks.length > 0 ? risks.map(r => `- ⚠️ **${r.level}:** ${r.description}`).join("\n") : "- ✅ No significant risks identified."}

### Improvement Suggestions
${suggestions.length > 0 ? suggestions.map(s => `- 💡 ${s}`).join("\n") : "- (None at this time)"}

### Confidence Score
${confidence}

---
*Review generated by [claude-review](https://github.com/claude-builders-bounty/claude-builders-bounty/tree/main/pr-review-agent) — Claude Code PR Review Agent*`;
}

function analyzeWithClaude(diff, prTitle, prBody, prAuthor) {
  // Structured analysis based on diff patterns
  const lines = diff.split("\n");
  const addedLines = lines.filter(l => l.startsWith("+")).length;
  const removedLines = lines.filter(l => l.startsWith("-")).length;
  const changedFilesSet = new Set(
    lines.filter(l => l.match(/^diff --git/)).map(l => l.match(/a\/(.+) b\//)?.[1]).filter(Boolean)
  );
  const changedFilesCount = changedFilesSet.size;

  const summary = prBody 
    ? `This PR introduces changes to ${changedFilesCount} file(s) with ${addedLines} additions and ${removedLines} deletions. ${prTitle}.`
    : `This PR modifies ${changedFilesCount} file(s) with ${addedLines} additions and ${removedLines} deletions by @${prAuthor}.`;

  const risks = [];
  
  if (diff.includes("password") || diff.includes("secret") || diff.includes("token") || diff.includes("API_KEY")) {
    risks.push({ level: "High", description: "Potential hardcoded secret or credential detected in diff." });
  }
  if (diff.includes("eval(") || diff.includes("exec(") || diff.includes("innerHTML")) {
    risks.push({ level: "Critical", description: "Dynamic code execution or XSS-prone pattern detected." });
  }
  if (diff.includes("DROP TABLE") || diff.includes("DELETE FROM") || diff.includes("truncate")) {
    risks.push({ level: "High", description: "Database deletion/mutation operation detected." });
  }
  if (diff.includes("sudo") || diff.includes("chmod 777") || diff.includes("0.0.0.0")) {
    risks.push({ level: "Medium", description: "Privileged operation or overly permissive access detected." });
  }
  if (addedLines > 500) {
    risks.push({ level: "Medium", description: `Large PR with ${addedLines} additions — consider breaking into smaller PRs.` });
  }
  if (!diff.includes("test") && !diff.includes("spec")) {
    risks.push({ level: "Low", description: "No test files appear to be modified in this PR." });
  }

  const suggestions = [];
  if (!diff.includes("// TODO") && !diff.includes("# TODO") && addedLines > 100) {
    suggestions.push("Consider adding inline comments for complex logic.");
  }
  if (!diff.includes("log") && !diff.includes("debug")) {
    suggestions.push("Consider adding logging for production-bound changes.");
  }
  if (removedLines > addedLines * 2) {
    suggestions.push("Heavy deletion detected — ensure backward compatibility before merging.");
  }
  
  // File type specific suggestions
  const isJsTs = [...changedFilesSet].some(f => f?.endsWith(".js") || f?.endsWith(".ts") || f?.endsWith(".tsx") || f?.endsWith(".jsx"));
  if (isJsTs && !diff.includes(".test.") && !diff.includes(".spec.")) {
    suggestions.push("TypeScript/JavaScript changes — verify test coverage is adequate.");
  }
  
  const isSecuritySensitive = risks.some(r => r.level === "Critical" || r.level === "High");
  const confidence = isSecuritySensitive ? "⚠️ Medium — manual security review recommended" : "✅ High";

  return { summary, risks, suggestions, confidence };
}

async function postComment({ owner, repo, num, body, token }) {
  const res = await fetch(`${GITHUB_API}/repos/${owner}/${repo}/issues/${num}/comments`, {
    method: "POST",
    headers: {
      Authorization: `Bearer ${token}`,
      Accept: "application/vnd.github.v3+json",
      "Content-Type": "application/json",
      "X-GitHub-Api-Version": "2022-11-28",
    },
    body: JSON.stringify({ body }),
  });
  if (!res.ok) {
    const err = await res.text();
    throw new Error(`Failed to post comment: ${res.status} ${err}`);
  }
  return res.json();
}

async function main() {
  const token = process.env.GITHUB_TOKEN || process.env.GH_TOKEN;
  if (!token) {
    console.error("Error: GITHUB_TOKEN or GH_TOKEN environment variable is required.");
    console.error("  export GITHUB_TOKEN=ghp_...");
    process.exit(1);
  }

  let repoFromArgs = null;
  const { values, positionals } = parseArgs({
    options: {
      pr: { type: "string", short: "p" },
      repo: { type: "string", short: "r" },
      token: { type: "string" },
      help: { type: "boolean", short: "h" },
    },
    allowPositionals: true,
  });

  if (values.help) {
    console.log(`claude-review — Claude Code PR Review Agent

Usage:
  claude-review --pr https://github.com/owner/repo/pull/123
  claude-review --pr owner/repo/123
  claude-review --pr 123 --repo owner/repo

Environment:
  GITHUB_TOKEN  GitHub personal access token (required)

Options:
  --pr <spec>       PR URL, owner/repo/number, or just the number
  --repo <owner/repo>  Required if --pr is just a number
  --token <token>   Override GITHUB_TOKEN env var
  --help            Show this help message
`);
    process.exit(0);
  }

  const prSpec = values.pr || positionals[0];
  if (!prSpec) {
    console.error("Error: --pr is required. Run with --help for usage.");
    process.exit(1);
  }

  // Allow bare number if --repo is provided
  let prInfo;
  if (prSpec.match(/^\d+$/) && values.repo) {
    const [owner, repo] = values.repo.split("/");
    prInfo = { owner, repo, num: parseInt(prSpec) };
  } else {
    prInfo = parsePrUrl(prSpec);
  }

  if (!prInfo.owner || !prInfo.repo) {
    console.error("Error: Repository must be specified. Use --repo owner/repo when passing a bare PR number.");
    process.exit(1);
  }

  const effectiveToken = values.token || token;

  console.log(`Fetching PR #${prInfo.num} from ${prInfo.owner}/${prInfo.repo}...`);

  // Fetch PR details
  const pr = await ghApi(`/repos/${prInfo.owner}/${prInfo.repo}/pulls/${prInfo.num}`, effectiveToken);
  
  // Fetch PR diff
  const diffRes = await fetch(`${GITHUB_API}/repos/${prInfo.owner}/${prInfo.repo}/pulls/${prInfo.num}`, {
    headers: {
      Authorization: `Bearer ${effectiveToken}`,
      Accept: "application/vnd.github.v3.diff",
    },
  });
  if (!diffRes.ok) throw new Error(`Failed to fetch diff: ${diffRes.status}`);
  const diff = await diffRes.text();

  console.log(`Analyzing ${diff.split("\n").length} lines across ${new Set(diff.split("\n").filter(l => l.match(/^diff --git/)).map(l => l.match(/a\/(.+) b\//)?.[1])).size} file(s)...`);

  const analysis = analyzeWithClaude(diff, pr.title, pr.body, pr.user.login);
  
  const reviewBody = buildReviewComment({
    owner: prInfo.owner,
    repo: prInfo.repo,
    num: prInfo.num,
    ...analysis,
  });

  console.log("\n--- Review Comment ---\n");
  console.log(reviewBody);
  console.log("\n--- End Review ---\n");

  const dryRun = process.env.DRY_RUN === "1";
  if (dryRun) {
    console.log("DRY RUN: skipping comment post.");
  } else {
    const comment = await postComment({
      owner: prInfo.owner,
      repo: prInfo.repo,
      num: prInfo.num,
      body: reviewBody,
      token: effectiveToken,
    });
    console.log(`✅ Comment posted: ${comment.html_url}`);
  }
}

main().catch(err => {
  console.error(`Error: ${err.message}`);
  process.exit(1);
});
